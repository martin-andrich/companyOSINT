@page "/de/email-aendern-bestaetigen"
@using companyOSINT.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using System.Text
@inject UserManager<ApplicationUser> UserManager

<PageTitle>E-Mail-Änderung bestätigen - company-OSINT.com</PageTitle>

<section class="content-page">
    <div class="container">
        <div class="auth-card text-center">
            @if (confirmed)
            {
                <i class="bi bi-check-circle fs-1 text-success d-block mb-3"></i>
                <h1 class="h3 mb-3">E-Mail-Adresse geändert</h1>
                <p class="text-muted mb-4">
                    Ihre E-Mail-Adresse wurde erfolgreich geändert.
                </p>
                <a href="/de/dashboard/konto" class="btn btn-primary">Zurück zum Konto</a>
            }
            else
            {
                <i class="bi bi-x-circle fs-1 text-danger d-block mb-3"></i>
                <h1 class="h3 mb-3">Änderung fehlgeschlagen</h1>
                <p class="text-muted mb-4">
                    Der Bestätigungslink ist ungültig oder abgelaufen. Bitte versuchen Sie es erneut über Ihre Kontoeinstellungen.
                </p>
                <a href="/de/dashboard/konto" class="btn btn-primary">Zurück zum Konto</a>
            }
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery]
    private string? UserId { get; set; }

    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    private bool confirmed;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(UserId) || string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Code))
            return;

        var user = await UserManager.FindByIdAsync(UserId);
        if (user is null)
            return;

        var token = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
        var result = await UserManager.ChangeEmailAsync(user, Email, token);

        if (result.Succeeded)
        {
            await UserManager.SetUserNameAsync(user, Email);
            confirmed = true;
        }
    }
}
