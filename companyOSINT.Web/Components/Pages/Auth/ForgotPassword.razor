@page "/de/passwort-vergessen"
@using System.Text
@using System.Text.Encodings.Web
@using companyOSINT.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@inject UserManager<ApplicationUser> UserManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject NavigationManager Navigation
@inject ILogger<ForgotPassword> Logger

<PageTitle>Passwort vergessen - company-OSINT.com</PageTitle>

<section class="content-page">
    <div class="container">
        <div class="text-center mb-4">
            <h1 class="h3">Passwort vergessen?</h1>
            <p class="text-muted">Geben Sie Ihre E-Mail-Adresse ein, um Ihr Passwort zurückzusetzen.</p>
        </div>

        <div class="auth-card">
            <form method="post" @formname="forgotPassword" @onsubmit="OnSubmitAsync">
                <AntiforgeryToken />
                <div class="mb-3">
                    <label for="email" class="form-label">E-Mail-Adresse</label>
                    <input type="email" class="form-control" id="email" name="Input.Email"
                           placeholder="name@firma.de" @bind="Input.Email" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">
                    Link zum Zurücksetzen senden
                </button>
            </form>
            <hr class="my-4" />
            <p class="text-center small mb-0">
                <a href="/de/anmelden" class="text-decoration-none">Zurück zur Anmeldung</a>
            </p>
        </div>
    </div>
</section>

@code {
    private ForgotPasswordInput _input = new();

    [SupplyParameterFromForm]
    private ForgotPasswordInput Input { get => _input; set => _input = value ?? new(); }

    private async Task OnSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);

        if (user is not null && await UserManager.IsEmailConfirmedAsync(user))
        {
            try
            {
                var token = await UserManager.GeneratePasswordResetTokenAsync(user);
                var code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(token));
                var resetLink = Navigation.ToAbsoluteUri(
                    $"/de/passwort-zuruecksetzen?code={code}").AbsoluteUri;

                await EmailSender.SendPasswordResetLinkAsync(user, Input.Email, resetLink);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Passwort-Reset-E-Mail konnte nicht an {Email} gesendet werden", Input.Email);
            }
        }

        // Immer weiterleiten, um nicht preiszugeben ob die E-Mail existiert
        Navigation.NavigateTo("/de/passwort-vergessen-bestaetigung", forceLoad: true);
    }

    private sealed class ForgotPasswordInput
    {
        public string Email { get; set; } = string.Empty;
    }
}
