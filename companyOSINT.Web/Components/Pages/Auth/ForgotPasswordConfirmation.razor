@page "/de/passwort-vergessen-bestaetigung"

<PageTitle>Passwort zurücksetzen - company-OSINT.com</PageTitle>

<section class="content-page">
    <div class="container">
        <div class="auth-card text-center">
            <i class="bi bi-envelope-check fs-1 text-primary d-block mb-3"></i>
            <h1 class="h3 mb-3">Prüfen Sie Ihr Postfach</h1>
            <p class="text-muted mb-4">
                Falls ein Konto mit dieser E-Mail-Adresse existiert, haben wir Ihnen einen Link
                zum Zurücksetzen Ihres Passworts gesendet. Bitte prüfen Sie auch Ihren Spam-Ordner.
            </p>
            <hr class="my-4" />
            <p class="small text-muted mb-0">
                <a href="/de/anmelden" class="text-decoration-none">Zurück zur Anmeldung</a>
            </p>
        </div>
    </div>
</section>
