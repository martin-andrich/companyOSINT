@page "/de/anmelden"
@using companyOSINT.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation

<PageTitle>Anmelden - company-OSINT.com</PageTitle>

<section class="content-page">
    <div class="container">
        <div class="text-center mb-4">
            <h1 class="h3">Willkommen zurück</h1>
            <p class="text-muted">Melden Sie sich in Ihrem Konto an.</p>
        </div>

        <div class="auth-card">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i> @errorMessage
                </div>
            }

            <form method="post" @formname="login" @onsubmit="OnSubmitAsync">
                <AntiforgeryToken />
                <div class="mb-3">
                    <label for="email" class="form-label">E-Mail-Adresse</label>
                    <input type="email" class="form-control" id="email" name="Input.Email"
                           placeholder="name@firma.de" @bind="Input.Email" required />
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Passwort</label>
                    <input type="password" class="form-control" id="password" name="Input.Password"
                           placeholder="Ihr Passwort" @bind="Input.Password" required />
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="remember"
                               name="Input.RememberMe" @bind="Input.RememberMe" />
                        <label class="form-check-label small" for="remember">Angemeldet bleiben</label>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100">
                    Anmelden
                </button>
            </form>
            <hr class="my-4" />
            <p class="text-center small mb-0">
                Noch kein Konto?
                <a href="/de/registrieren" class="text-decoration-none">Jetzt registrieren</a>
            </p>
        </div>
    </div>
</section>

@code {
    private LoginInput _input = new();

    [SupplyParameterFromForm]
    private LoginInput Input { get => _input; set => _input = value ?? new(); }

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private string? errorMessage;

    private async Task OnSubmitAsync()
    {
        var result = await SignInManager.PasswordSignInAsync(
            Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: false);

        if (result.Succeeded)
        {
            var redirectUrl = string.IsNullOrEmpty(ReturnUrl) ? "/de/dashboard" : ReturnUrl;
            Navigation.NavigateTo(redirectUrl, forceLoad: true);
            return;
        }

        if (result.RequiresTwoFactor)
        {
            var returnUrlParam = string.IsNullOrEmpty(ReturnUrl) ? "" : $"&returnUrl={Uri.EscapeDataString(ReturnUrl)}";
            Navigation.NavigateTo($"/de/zwei-faktor?rememberMe={Input.RememberMe}{returnUrlParam}", forceLoad: true);
            return;
        }

        if (result.IsLockedOut)
        {
            errorMessage = "Ihr Konto wurde vorübergehend gesperrt. Bitte versuchen Sie es später erneut.";
        }
        else if (result.IsNotAllowed)
        {
            errorMessage = "Ihre E-Mail-Adresse wurde noch nicht bestätigt. Bitte prüfen Sie Ihr Postfach.";
        }
        else
        {
            errorMessage = "Ungültige E-Mail-Adresse oder falsches Passwort.";
        }
    }

    private sealed class LoginInput
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public bool RememberMe { get; set; }
    }
}
