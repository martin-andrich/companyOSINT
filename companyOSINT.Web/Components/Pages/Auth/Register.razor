@page "/de/registrieren"
@using System.Text.Encodings.Web
@using companyOSINT.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using System.Text
@inject UserManager<ApplicationUser> UserManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject NavigationManager Navigation

<PageTitle>Registrieren - company-OSINT.com</PageTitle>

<section class="content-page">
    <div class="container">
        <div class="text-center mb-4">
            <h1 class="h3">Konto erstellen</h1>
            <p class="text-muted">Starten Sie kostenlos mit company-OSINT.com.</p>
        </div>

        <div class="auth-card">
            @if (errors.Count > 0)
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    <ul class="mb-0 ps-3">
                        @foreach (var error in errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <form method="post" @formname="register" @onsubmit="OnSubmitAsync">
                <AntiforgeryToken />
                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label for="firstName" class="form-label">Vorname</label>
                        <input type="text" class="form-control" id="firstName" name="Input.FirstName"
                               placeholder="Max" @bind="Input.FirstName" required />
                    </div>
                    <div class="col-sm-6">
                        <label for="lastName" class="form-label">Nachname</label>
                        <input type="text" class="form-control" id="lastName" name="Input.LastName"
                               placeholder="Mustermann" @bind="Input.LastName" required />
                    </div>
                </div>
                <div class="mb-3">
                    <label for="company" class="form-label">Firma <span class="text-muted">(optional)</span></label>
                    <input type="text" class="form-control" id="company" name="Input.CompanyName"
                           placeholder="Firma GmbH" @bind="Input.CompanyName" />
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">E-Mail-Adresse</label>
                    <input type="email" class="form-control" id="email" name="Input.Email"
                           placeholder="name@firma.de" @bind="Input.Email" required />
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Passwort</label>
                    <input type="password" class="form-control" id="password" name="Input.Password"
                           placeholder="Mindestens 8 Zeichen" @bind="Input.Password" required />
                </div>
                <div class="mb-3">
                    <label for="passwordConfirm" class="form-label">Passwort bestätigen</label>
                    <input type="password" class="form-control" id="passwordConfirm" name="Input.PasswordConfirm"
                           placeholder="Passwort wiederholen" @bind="Input.PasswordConfirm" required />
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="terms" name="Input.AcceptTerms"
                           value="true" @bind="Input.AcceptTerms" />
                    <label class="form-check-label small" for="terms">
                        Ich akzeptiere die <a href="/de/datenschutz" class="text-decoration-none">Datenschutzerklärung</a>.
                    </label>
                </div>
                <button type="submit" class="btn btn-primary w-100">
                    Konto erstellen
                </button>
            </form>
            <hr class="my-4" />
            <p class="text-center small mb-0">
                Bereits ein Konto?
                <a href="/de/anmelden" class="text-decoration-none">Jetzt anmelden</a>
            </p>
        </div>
    </div>
</section>

@code {
    private RegisterInput _input = new();

    [SupplyParameterFromForm]
    private RegisterInput Input { get => _input; set => _input = value ?? new(); }

    private List<string> errors = new();

    private async Task OnSubmitAsync()
    {
        errors.Clear();

        if (!Input.AcceptTerms)
        {
            errors.Add("Bitte akzeptieren Sie die Datenschutzerklärung.");
            return;
        }

        if (Input.Password != Input.PasswordConfirm)
        {
            errors.Add("Die Passwörter stimmen nicht überein.");
            return;
        }

        var user = new ApplicationUser
        {
            UserName = Input.Email,
            Email = Input.Email,
            FirstName = Input.FirstName,
            LastName = Input.LastName,
            CompanyName = string.IsNullOrWhiteSpace(Input.CompanyName) ? null : Input.CompanyName,
            DateCreated = DateTime.UtcNow
        };

        var result = await UserManager.CreateAsync(user, Input.Password);

        if (result.Succeeded)
        {
            var token = await UserManager.GenerateEmailConfirmationTokenAsync(user);
            var code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(token));
            var confirmationLink = Navigation.ToAbsoluteUri(
                $"/de/email-bestaetigen?userId={user.Id}&code={code}").AbsoluteUri;

            await EmailSender.SendConfirmationLinkAsync(user, Input.Email, confirmationLink);
            Navigation.NavigateTo("/de/registrierung-bestaetigung", forceLoad: true);
            return;
        }

        foreach (var error in result.Errors)
        {
            errors.Add(TranslateError(error.Code));
        }
    }

    private static string TranslateError(string errorCode) => errorCode switch
    {
        "DuplicateUserName" or "DuplicateEmail" => "Diese E-Mail-Adresse wird bereits verwendet.",
        "PasswordTooShort" => "Das Passwort muss mindestens 8 Zeichen lang sein.",
        "PasswordRequiresDigit" => "Das Passwort muss mindestens eine Ziffer enthalten.",
        "PasswordRequiresUpper" => "Das Passwort muss mindestens einen Grossbuchstaben enthalten.",
        "PasswordRequiresLower" => "Das Passwort muss mindestens einen Kleinbuchstaben enthalten.",
        "PasswordRequiresNonAlphanumeric" => "Das Passwort muss mindestens ein Sonderzeichen enthalten.",
        "InvalidEmail" => "Die E-Mail-Adresse ist ungueltig.",
        _ => "Ein unbekannter Fehler ist aufgetreten. Bitte versuchen Sie es erneut."
    };

    private sealed class RegisterInput
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string? CompanyName { get; set; }
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string PasswordConfirm { get; set; } = string.Empty;
        public bool AcceptTerms { get; set; }
    }
}
