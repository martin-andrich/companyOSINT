@page "/de/registrierung-bestaetigung"

<PageTitle>Registrierung bestätigen - company-OSINT.com</PageTitle>

<section class="content-page">
    <div class="container">
        <div class="auth-card text-center">
            <i class="bi bi-envelope-check fs-1 text-primary d-block mb-3"></i>
            <h1 class="h3 mb-3">Prüfen Sie Ihr Postfach</h1>
            <p class="text-muted mb-4">
                Wir haben Ihnen eine E-Mail mit einem Bestätigungslink gesendet.
                Klicken Sie auf den Link, um Ihre E-Mail-Adresse zu bestätigen und Ihr Konto zu aktivieren.
            </p>
            <hr class="my-4" />
            <p class="small text-muted mb-0">
                Keine E-Mail erhalten? Prüfen Sie Ihren Spam-Ordner oder
                <a href="/de/registrieren" class="text-decoration-none">registrieren Sie sich erneut</a>.
            </p>
        </div>
    </div>
</section>
