@page "/de/passwort-zuruecksetzen-bestaetigung"

<PageTitle>Passwort zurückgesetzt - company-OSINT.com</PageTitle>

<section class="content-page">
    <div class="container">
        <div class="auth-card text-center">
            <i class="bi bi-check-circle fs-1 text-success d-block mb-3"></i>
            <h1 class="h3 mb-3">Passwort zurückgesetzt</h1>
            <p class="text-muted mb-4">
                Ihr Passwort wurde erfolgreich geändert. Sie können sich jetzt mit Ihrem neuen Passwort anmelden.
            </p>
            <a href="/de/anmelden" class="btn btn-primary">Jetzt anmelden</a>
        </div>
    </div>
</section>
