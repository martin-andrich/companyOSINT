@page "/de/dashboard/api-token"
@layout DashboardLayout
@rendermode RenderMode.InteractiveServer
@attribute [Authorize]
@using companyOSINT.Application.Interfaces
@using companyOSINT.Domain.Dtos.ApiTokens
@using companyOSINT.Domain.Entities
@using companyOSINT.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@inject IApiTokenService TokenService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>API-Token - company-OSINT.com</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">API-Token</h1>
    <button class="btn btn-primary btn-sm" @onclick="() => showCreateForm = !showCreateForm">
        <i class="bi bi-plus-lg me-1"></i>Neuer Token
    </button>
</div>

@* Token erstellen *@
@if (showCreateForm)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h6 class="mb-3">Neuen API-Token erstellen</h6>

            @if (createErrors.Count > 0)
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    @foreach (var error in createErrors)
                    {
                        <span>@error</span>
                    }
                </div>
            }

            <div class="row g-3">
                <div class="col-sm-6">
                    <label for="tokenName" class="form-label text-muted small mb-1">Name</label>
                    <input type="text" class="form-control" id="tokenName"
                           @bind="newTokenName" placeholder="z.B. Produktions-Token" />
                </div>
                <div class="col-sm-6">
                    <label for="expiresAt" class="form-label text-muted small mb-1">Gültig bis</label>
                    <input type="date" class="form-control" id="expiresAt"
                           @bind="newTokenExpiry" min="@DateTime.UtcNow.AddDays(1).ToString("yyyy-MM-dd")" />
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-primary btn-sm" @onclick="CreateTokenAsync"
                        disabled="@(string.IsNullOrWhiteSpace(newTokenName) || isCreating)">
                    @if (isCreating)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    <i class="bi bi-check-lg me-1"></i>Erstellen
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="CancelCreate">
                    Abbrechen
                </button>
            </div>
        </div>
    </div>
}

@* Neu erstellter Token (einmalig anzeigen) *@
@if (createdPlainToken is not null)
{
    <div class="alert alert-success mb-4">
        <div class="d-flex align-items-center mb-2">
            <i class="bi bi-check-circle me-2"></i>
            <strong>Token erstellt</strong>
        </div>
        <p class="mb-2 small">
            Kopieren Sie den Token jetzt. Er wird aus Sicherheitsgründen nicht erneut angezeigt.
        </p>
        <div class="input-group">
            <input type="text" class="form-control font-monospace" value="@createdPlainToken" readonly />
            <button class="btn btn-outline-secondary" @onclick="CopyToken" title="Token kopieren">
                <i class="bi @(copied ? "bi-check-lg" : "bi-clipboard")"></i>
            </button>
        </div>
    </div>
}

@* Token-Tabelle *@
@if (tokens.Count > 0)
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="border-bottom-2">Name</th>
                        <th class="border-bottom-2">Token</th>
                        <th class="border-bottom-2">Erstellt am</th>
                        <th class="border-bottom-2">Gültig bis</th>
                        <th class="border-bottom-2">Status</th>
                        <th class="border-bottom-2"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var token in tokens)
                    {
                        <tr>
                            <td class="fw-medium">@token.Name</td>
                            <td>
                                <code class="text-muted">@(token.TokenPrefix)…</code>
                            </td>
                            <td class="text-muted">@token.DateCreated.ToString("dd.MM.yyyy")</td>
                            <td class="text-muted">@token.ExpiresAt.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (token.ExpiresAt < DateTime.UtcNow)
                                {
                                    <span class="badge bg-danger">Abgelaufen</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Aktiv</span>
                                }
                            </td>
                            <td>
                                @if (deleteConfirmId == token.Id)
                                {
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteTokenAsync(token.Id)">
                                            Löschen
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => deleteConfirmId = null">
                                            Abbrechen
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-outline-danger btn-sm"
                                            @onclick="() => deleteConfirmId = token.Id"
                                            title="Token löschen">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else if (!showCreateForm)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-key fs-1 text-muted mb-3 d-block"></i>
            <h5>Keine API-Token vorhanden</h5>
            <p class="text-muted mb-3">
                Erstellen Sie einen Token, um den MCP-Server zu nutzen.
            </p>
            <button class="btn btn-primary" @onclick="() => showCreateForm = true">
                <i class="bi bi-plus-lg me-1"></i>Neuen Token erstellen
            </button>
        </div>
    </div>
}

@code {
    private Guid userId;
    private List<ApiToken> tokens = [];

    // Create form
    private bool showCreateForm;
    private string newTokenName = "";
    private DateTime newTokenExpiry = DateTime.UtcNow.AddMonths(3).Date;
    private bool isCreating;
    private List<string> createErrors = [];
    private string? createdPlainToken;
    private bool copied;

    // Delete
    private Guid? deleteConfirmId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user is null) return;
        userId = user.Id;

        tokens = await TokenService.GetByUserAsync(userId);
    }

    private async Task CreateTokenAsync()
    {
        createErrors.Clear();
        createdPlainToken = null;
        copied = false;

        if (string.IsNullOrWhiteSpace(newTokenName))
        {
            createErrors.Add("Bitte geben Sie einen Namen ein.");
            return;
        }

        if (newTokenExpiry <= DateTime.UtcNow)
        {
            createErrors.Add("Das Ablaufdatum muss in der Zukunft liegen.");
            return;
        }

        isCreating = true;
        try
        {
            var (_, plainToken) = await TokenService.CreateAsync(userId, new ApiTokenCreateDto
            {
                Name = newTokenName.Trim(),
                ExpiresAt = DateTime.SpecifyKind(newTokenExpiry, DateTimeKind.Utc),
            });

            createdPlainToken = plainToken;
            newTokenName = "";
            newTokenExpiry = DateTime.UtcNow.AddMonths(3).Date;
            showCreateForm = false;

            tokens = await TokenService.GetByUserAsync(userId);
        }
        finally
        {
            isCreating = false;
        }
    }

    private void CancelCreate()
    {
        showCreateForm = false;
        newTokenName = "";
        createErrors.Clear();
    }

    private void CopyToken()
    {
        copied = true;
    }

    private async Task DeleteTokenAsync(Guid tokenId)
    {
        await TokenService.DeleteAsync(tokenId, userId);
        deleteConfirmId = null;
        tokens = await TokenService.GetByUserAsync(userId);

        if (createdPlainToken is not null)
            createdPlainToken = null;
    }
}
