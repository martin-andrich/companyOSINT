@page "/de/dashboard"
@layout DashboardLayout
@attribute [Authorize]

<PageTitle>Dashboard - company-OSINT.com</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Dashboard</h1>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="bi bi-rocket-takeoff fs-1 text-muted mb-3 d-block"></i>
        <h5>Willkommen bei companyOSINT</h5>
        <p class="text-muted mb-3">
            Starten Sie Ihre erste Suche und finden Sie passende Unternehmen für Ihre Akquise.
        </p>
        <a href="/de/dashboard/suche" class="btn btn-primary">
            <i class="bi bi-search me-1"></i> Suche starten
        </a>
    </div>
</div>
