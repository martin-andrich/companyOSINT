@page "/de/Demo"
@rendermode RenderMode.InteractiveServer
@using Microsoft.JSInterop
@using companyOSINT.Application.Interfaces
@using companyOSINT.Domain.Common
@using companyOSINT.Domain.Entities
@inject ICompanyService CompanyService
@inject ISectorService SectorService
@inject IPostalCodeService PostalCodeService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Demo – company-OSINT.com</PageTitle>

<div class="content-page">
    <div class="container">
        <h1><i class="bi bi-search me-2 text-primary"></i>Firmen suchen</h1>
        <p class="text-muted mb-4">Durchsuchen Sie unsere Datenbank mit deutschen Unternehmen nach Postleitzahl, Umkreis, Branche und technischen Details.</p>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <div class="row g-3">
                    @* PLZ Input *@
                    <div class="col-md-3">
                        <label for="plzInput" class="form-label fw-semibold">
                            <i class="bi bi-geo-alt me-1"></i>Postleitzahl
                        </label>
                        <div class="input-group">
                            <input type="text" id="plzInput" class="form-control" placeholder="z.B. 01069"
                                   maxlength="5" inputmode="numeric" pattern="[0-9]*"
                                   @bind="plz" @bind:event="oninput" @bind:after="OnFilterChangedAsync" />
                            <button class="btn btn-outline-secondary" type="button"
                                    title="Standort ermitteln" disabled="@isLocating"
                                    @onclick="LocateAsync">
                                @if (isLocating)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                else
                                {
                                    <i class="bi bi-crosshair"></i>
                                }
                            </button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(resolvedPlaceName))
                        {
                            <small class="text-success mt-1 d-block">
                                <i class="bi bi-check-circle me-1"></i>@resolvedPlaceName
                            </small>
                        }
                        else if (plz.Length == 5)
                        {
                            <small class="text-danger mt-1 d-block">
                                <i class="bi bi-exclamation-circle me-1"></i>PLZ nicht gefunden
                            </small>
                        }
                        @if (locationError is not null)
                        {
                            <small class="text-danger mt-1 d-block">
                                <i class="bi bi-exclamation-triangle me-1"></i>@locationError
                            </small>
                        }
                    </div>

                    @* Radius Slider *@
                    <div class="col-md-3">
                        <label for="radiusSlider" class="form-label fw-semibold">
                            <i class="bi bi-bullseye me-1"></i>Umkreis: <span class="text-primary">@radiusKm km</span>
                        </label>
                        <input type="range" id="radiusSlider" class="form-range" min="0" max="100" step="10"
                               @bind="radiusKm" @bind:after="OnFilterChangedAsync"
                               disabled="@string.IsNullOrWhiteSpace(plz)" />
                        <div class="d-flex justify-content-between">
                            <small class="text-muted">0 km</small>
                            <small class="text-muted">100 km</small>
                        </div>
                    </div>

                    @* Sector Multi-Select *@
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-briefcase me-1"></i>Branche
                        </label>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center"
                                    type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                    data-bs-auto-close="outside">
                                @if (selectedSectorIds.Count == 0)
                                {
                                    <span class="text-muted">Alle Branchen</span>
                                }
                                else
                                {
                                    <span>@selectedSectorIds.Count Branche(n) ausgewählt</span>
                                }
                            </button>
                            <div class="dropdown-menu w-100 p-2" style="max-height: 300px; overflow-y: auto;">
                                @if (selectedSectorIds.Count > 0)
                                {
                                    <button type="button" class="btn btn-sm btn-link text-decoration-none mb-1"
                                            @onclick="ClearSectorsAsync">
                                        <i class="bi bi-x-circle me-1"></i>Auswahl aufheben
                                    </button>
                                    <div class="dropdown-divider"></div>
                                }
                                @foreach (var sector in sectors)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="@($"sector-{sector.Id}")"
                                               checked="@selectedSectorIds.Contains(sector.Id)"
                                               @onchange="e => ToggleSectorAsync(sector.Id, (bool)e.Value!)" />
                                        <label class="form-check-label" for="@($"sector-{sector.Id}")">
                                            @sector.Name
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 align-items-end mt-1">
                    @* Software Multi-Select *@
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-code-slash me-1"></i>Software
                        </label>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center"
                                    type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                    data-bs-auto-close="outside">
                                @if (selectedSoftwareNames.Count == 0)
                                {
                                    <span class="text-muted">Alle</span>
                                }
                                else
                                {
                                    <span>@selectedSoftwareNames.Count ausgewaehlt</span>
                                }
                            </button>
                            <div class="dropdown-menu w-100 p-2" style="max-height: 300px; overflow-y: auto;">
                                @if (selectedSoftwareNames.Count > 0)
                                {
                                    <button type="button" class="btn btn-sm btn-link text-decoration-none mb-1"
                                            @onclick="ClearSoftwareAsync">
                                        <i class="bi bi-x-circle me-1"></i>Auswahl aufheben
                                    </button>
                                    <div class="dropdown-divider"></div>
                                }
                                @foreach (var name in softwareNames)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="@($"sw-{name}")"
                                               checked="@selectedSoftwareNames.Contains(name)"
                                               @onchange="e => ToggleSoftwareAsync(name, (bool)e.Value!)" />
                                        <label class="form-check-label" for="@($"sw-{name}")">
                                            @name
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    @* Tools Multi-Select *@
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-tools me-1"></i>Tools
                        </label>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center"
                                    type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                    data-bs-auto-close="outside">
                                @if (selectedToolNames.Count == 0)
                                {
                                    <span class="text-muted">Alle</span>
                                }
                                else
                                {
                                    <span>@selectedToolNames.Count ausgewaehlt</span>
                                }
                            </button>
                            <div class="dropdown-menu w-100 p-2" style="max-height: 300px; overflow-y: auto;">
                                @if (selectedToolNames.Count > 0)
                                {
                                    <button type="button" class="btn btn-sm btn-link text-decoration-none mb-1"
                                            @onclick="ClearToolsAsync">
                                        <i class="bi bi-x-circle me-1"></i>Auswahl aufheben
                                    </button>
                                    <div class="dropdown-divider"></div>
                                }
                                @foreach (var name in toolNames)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="@($"tool-{name}")"
                                               checked="@selectedToolNames.Contains(name)"
                                               @onchange="e => ToggleToolAsync(name, (bool)e.Value!)" />
                                        <label class="form-check-label" for="@($"tool-{name}")">
                                            @name
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    @* Website Filter *@
                    <div class="col-md-2">
                        <label for="websiteFilter" class="form-label fw-semibold">
                            <i class="bi bi-globe me-1"></i>Website
                        </label>
                        <select id="websiteFilter" class="form-select"
                                @bind="websiteFilter" @bind:after="OnFilterChangedAsync">
                            <option value="">Alle</option>
                            <option value="with">Mit Website</option>
                            <option value="without">Ohne Website</option>
                        </select>
                    </div>

                    @* SSL Filter *@
                    <div class="col-md-2">
                        <label for="sslFilter" class="form-label fw-semibold">
                            <i class="bi bi-shield-lock me-1"></i>SSL
                        </label>
                        <select id="sslFilter" class="form-select"
                                @bind="sslFilter" @bind:after="OnFilterChangedAsync">
                            <option value="">Alle</option>
                            <option value="valid">Nur valides SSL</option>
                            <option value="invalid">Nur invalides SSL</option>
                        </select>
                    </div>

                    @* CMP Filter *@
                    <div class="col-md-2">
                        <label for="cmpFilter" class="form-label fw-semibold">
                            <i class="bi bi-cookie me-1"></i>CMP
                        </label>
                        <select id="cmpFilter" class="form-select"
                                @bind="cmpFilter" @bind:after="OnFilterChangedAsync">
                            <option value="">Alle</option>
                            <option value="with">Nur mit CMP</option>
                            <option value="without">Nur ohne CMP</option>
                        </select>
                    </div>

                    @* TTFB / Ladezeit Filter *@
                    <div class="col-md-2">
                        <label for="ttfbFilter" class="form-label fw-semibold">
                            <i class="bi bi-speedometer2 me-1"></i>Ladezeit
                        </label>
                        <select id="ttfbFilter" class="form-select"
                                @bind="ttfbFilter" @bind:after="OnFilterChangedAsync">
                            <option value="">Alle</option>
                            <option value="fast">Schnell (&le; 0,8s)</option>
                            <option value="medium">Mittel (0,8–1,8s)</option>
                            <option value="slow">Langsam (&gt; 1,8s)</option>
                        </select>
                    </div>

                    @* Requests without consent Filter *@
                    <div class="col-md-3">
                        <label for="rwcFilter" class="form-label fw-semibold">
                            <i class="bi bi-exclamation-triangle me-1"></i>Nicht-DSGVO-konforme Requests
                        </label>
                        <select id="rwcFilter" class="form-select"
                                @bind="rwcFilter" @bind:after="OnFilterChangedAsync">
                            <option value="">Alle</option>
                            <option value="with">Vorhanden</option>
                            <option value="without">Keine vorhanden</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        @* Results *@
        @if (isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Laden...</span>
                </div>
                <p class="text-muted mt-2">Suche läuft...</p>
            </div>
        }
        else if (result is not null && result.Items.Count > 0)
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <p class="text-muted mb-0">
                    <strong>@result.TotalCount.ToString("N0")</strong> Ergebnis(se) gefunden
                </p>
                @if (result.TotalPages > 1)
                {
                    <small class="text-muted">Seite @result.Page von @result.TotalPages</small>
                }
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th class="border-bottom-2">Firma</th>
                            <th class="border-bottom-2">Anschrift</th>
                            <th class="border-bottom-2">Website</th>
                            <th class="border-bottom-2">Tätigkeit</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var company in result.Items)
                        {
                            <tr>
                                <td class="fw-medium">@company.Name</td>
                                <td class="text-muted">@company.RegisteredAddress</td>
                                <td>
                                    <span class="demo-blur" role="button" title="Anmelden, um Website zu sehen"
                                          @onclick="NavigateToDashboard">beispiel-website.de</span>
                                </td>
                                <td>
                                    <span class="demo-blur" role="button" title="Anmelden, um Tätigkeit zu sehen"
                                          @onclick="NavigateToDashboard">Beispieltätigkeit des Unternehmens</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Pagination *@
            @if (result.TotalPages > 1)
            {
                <nav aria-label="Seitennavigation" class="mt-3">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(result.Page <= 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPageAsync(result.Page - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        @foreach (var p in GetPageNumbers())
                        {
                            @if (p == -1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">&hellip;</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item @(p == result.Page ? "active" : "")">
                                    <button class="page-link" @onclick="() => GoToPageAsync(p)">@p</button>
                                </li>
                            }
                        }
                        <li class="page-item @(result.Page >= result.TotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPageAsync(result.Page + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            }
        }
        else if (hasSearched)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-emoji-neutral fs-1 d-block mb-3"></i>
                <p class="mb-1">Keine Ergebnisse gefunden.</p>
                <small>Versuchen Sie einen anderen Suchbegriff oder erweitern Sie den Umkreis.</small>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-building fs-1 d-block mb-3"></i>
                <p class="mb-1">Geben Sie eine Postleitzahl ein oder wählen Sie eine Branche,</p>
                <p>um die Suche zu starten.</p>
            </div>
        }
    </div>
</div>

@code {
    private string plz = "";
    private int radiusKm = 25;
    private List<Sector> sectors = [];
    private HashSet<Guid> selectedSectorIds = [];
    private List<string> softwareNames = [];
    private HashSet<string> selectedSoftwareNames = [];
    private List<string> toolNames = [];
    private HashSet<string> selectedToolNames = [];
    private string websiteFilter = "";
    private string sslFilter = "";
    private string cmpFilter = "";
    private string ttfbFilter = "";
    private string rwcFilter = "";
    private PaginatedResult<CompanySearchResultDto>? result;
    private bool isLoading;
    private bool hasSearched;
    private int currentPage = 1;
    private CancellationTokenSource? debounceCts;
    private string? resolvedPlaceName;
    private bool isLocating;
    private string? locationError;

    protected override async Task OnInitializedAsync()
    {
        sectors = await SectorService.GetAllAsync();
        softwareNames = KnownDetections.SoftwareNames.ToList();
        toolNames = KnownDetections.ToolNames.ToList();
    }

    private async Task LocateAsync()
    {
        isLocating = true;
        locationError = null;
        StateHasChanged();

        try
        {
            var coords = await JS.InvokeAsync<double[]>("eval", """
                new Promise((resolve, reject) => {
                    if (!navigator.geolocation) { reject('Geolocation nicht verfuegbar'); return; }
                    navigator.geolocation.getCurrentPosition(
                        pos => resolve([pos.coords.latitude, pos.coords.longitude]),
                        err => reject(err.message),
                        { enableHighAccuracy: false, timeout: 10000 }
                    );
                })
            """);

            var code = PostalCodeService.FindNearestCode(coords[0], coords[1]);
            if (code is not null)
            {
                plz = code;
                await OnFilterChangedAsync();
            }
            else
            {
                locationError = "Keine PLZ in der Naehe gefunden";
            }
        }
        catch
        {
            locationError = "Standort konnte nicht ermittelt werden";
        }
        finally
        {
            isLocating = false;
            StateHasChanged();
        }
    }

    private async Task OnFilterChangedAsync()
    {
        resolvedPlaceName = plz.Length == 5 ? PostalCodeService.GetPlaceName(plz) : null;
        currentPage = 1;
        await SearchAsync();
    }

    private async Task ToggleSectorAsync(Guid sectorId, bool isChecked)
    {
        if (isChecked)
            selectedSectorIds.Add(sectorId);
        else
            selectedSectorIds.Remove(sectorId);

        currentPage = 1;
        await SearchAsync();
    }

    private async Task ClearSectorsAsync()
    {
        selectedSectorIds.Clear();
        currentPage = 1;
        await SearchAsync();
    }

    private async Task ToggleSoftwareAsync(string name, bool isChecked)
    {
        if (isChecked) selectedSoftwareNames.Add(name); else selectedSoftwareNames.Remove(name);
        currentPage = 1;
        await SearchAsync();
    }

    private async Task ClearSoftwareAsync()
    {
        selectedSoftwareNames.Clear();
        currentPage = 1;
        await SearchAsync();
    }

    private async Task ToggleToolAsync(string name, bool isChecked)
    {
        if (isChecked) selectedToolNames.Add(name); else selectedToolNames.Remove(name);
        currentPage = 1;
        await SearchAsync();
    }

    private async Task ClearToolsAsync()
    {
        selectedToolNames.Clear();
        currentPage = 1;
        await SearchAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        if (result is null || page < 1 || page > result.TotalPages)
            return;

        currentPage = page;
        await SearchAsync();
    }

    private bool HasAnyFilter =>
        !string.IsNullOrWhiteSpace(plz) || selectedSectorIds.Count > 0 ||
        selectedSoftwareNames.Count > 0 || selectedToolNames.Count > 0 ||
        websiteFilter != "" || sslFilter != "" || cmpFilter != "" ||
        ttfbFilter != "" || rwcFilter != "";

    private async Task SearchAsync()
    {
        if (!HasAnyFilter)
        {
            result = null;
            hasSearched = false;
            return;
        }

        debounceCts?.Cancel();
        debounceCts = new CancellationTokenSource();
        var ct = debounceCts.Token;

        try
        {
            await Task.Delay(300, ct);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        isLoading = true;
        StateHasChanged();

        bool? hasWebsite = websiteFilter switch { "with" => true, "without" => false, _ => null };
        bool? sslValid = sslFilter switch { "valid" => true, "invalid" => false, _ => null };
        bool? cmpFound = cmpFilter switch { "with" => true, "without" => false, _ => null };

        try
        {
            result = await CompanyService.SearchAsync(
                plz, radiusKm,
                selectedSectorIds.Count > 0 ? selectedSectorIds.ToList() : null,
                selectedSoftwareNames.Count > 0 ? selectedSoftwareNames.ToList() : null,
                selectedToolNames.Count > 0 ? selectedToolNames.ToList() : null,
                sslValid, cmpFound, hasWebsite,
                string.IsNullOrEmpty(ttfbFilter) ? null : ttfbFilter,
                rwcFilter switch { "with" => true, "without" => false, _ => (bool?)null },
                currentPage, 25, ct);

            // Strip sensitive data — demo page must not leak Website/Activity to the client
            foreach (var item in result.Items)
            {
                item.Website = null;
                item.Activity = null;
            }

            hasSearched = true;
        }
        catch (TaskCanceledException)
        {
            // Ignored
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private List<int> GetPageNumbers()
    {
        if (result is null) return [];

        var total = result.TotalPages;
        var current = result.Page;
        var pages = new List<int>();

        if (total <= 7)
        {
            for (var i = 1; i <= total; i++)
                pages.Add(i);
        }
        else
        {
            pages.Add(1);

            if (current > 3)
                pages.Add(-1); // ellipsis

            for (var i = Math.Max(2, current - 1); i <= Math.Min(total - 1, current + 1); i++)
                pages.Add(i);

            if (current < total - 2)
                pages.Add(-1); // ellipsis

            pages.Add(total);
        }

        return pages;
    }

    private void NavigateToDashboard()
    {
        Navigation.NavigateTo("/de/dashboard");
    }
}
