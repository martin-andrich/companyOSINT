@page "/de"

<PageTitle>company-OSINT.com – Firmendatenbank für Ihre Akquise</PageTitle>

<!-- Hero -->
<section class="hero-section">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="container position-relative">
        <div class="row align-items-center g-5">
            <div class="col-lg-7">
                <div class="hero-badge">
                    <span class="badge-dot"></span>
                    2 Mio.+ Unternehmen verfügbar
                </div>
                <h1>Finden Sie genau<br />die Kunden, die zu<br />Ihnen passen</h1>
                <p class="lead mt-4 mb-5">
                    Durchsuchen Sie hunderttausende deutscher Unternehmen nach
                    Branche, Region, Software und Technologie &mdash; mit einer
                    Datenbank, die für gezielte B2B-Akquise gemacht ist.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="/de/registrieren" class="btn-hero-primary">
                        Kostenlos starten
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    <a href="/de/Demo" class="btn-hero-secondary">
                        <i class="bi bi-play-circle me-1"></i>
                        Demo ansehen
                    </a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block">
                <div class="hero-visual">
                    <div class="hero-card">
                        <div class="hero-card-row">
                            <div class="hero-card-icon" style="background: rgba(6,182,212,0.15); color: var(--fac-accent);">
                                <i class="bi bi-building"></i>
                            </div>
                            <span class="hero-card-text">Unternehmen</span>
                            <span class="hero-card-value">2.147.832</span>
                        </div>
                        <div class="hero-card-row">
                            <div class="hero-card-icon" style="background: rgba(79,70,229,0.15); color: var(--fac-primary);">
                                <i class="bi bi-globe2"></i>
                            </div>
                            <span class="hero-card-text">Websites</span>
                            <span class="hero-card-value">284.591</span>
                        </div>
                        <div class="hero-card-row">
                            <div class="hero-card-icon" style="background: rgba(124,58,237,0.15); color: var(--fac-secondary);">
                                <i class="bi bi-briefcase"></i>
                            </div>
                            <span class="hero-card-text">Branchen</span>
                            <span class="hero-card-value">65</span>
                        </div>
                        <div class="hero-card-row">
                            <div class="hero-card-icon" style="background: rgba(16,185,129,0.15); color: #10b981;">
                                <i class="bi bi-geo-alt"></i>
                            </div>
                            <span class="hero-card-text">Bundesländer</span>
                            <span class="hero-card-value">16</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="stats-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-number">2 Mio.+</div>
                    <div class="stat-label">Unternehmen</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-number">65</div>
                    <div class="stat-label">Branchen</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-number">16</div>
                    <div class="stat-label">Bundesländer</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <div class="stat-number">11+</div>
                    <div class="stat-label">CMS erkannt</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features – Bento Grid -->
<section class="section-spacing">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-label">
                <i class="bi bi-grid-3x3-gap"></i> Features
            </span>
            <h2>Alles für erfolgreiche Akquise</h2>
            <p>Qualifizierte Firmendaten, intelligent aufbereitet und sofort einsetzbar.</p>
        </div>

        <div class="bento-grid">
            <!-- Filter – breit -->
            <div class="bento-card bento-wide">
                <div class="bento-icon icon-blue">
                    <i class="bi bi-funnel"></i>
                </div>
                <h5>Intelligente Filter</h5>
                <p>
                    Filtern Sie nach Branche, Bundesland, Postleitzahl, Umkreis,
                    eingesetzter Software, SSL-Status und Consent-Management &mdash;
                    alles kombinierbar.
                </p>
                <div class="bento-tag-list">
                    <span class="bento-tag">Branche</span>
                    <span class="bento-tag">PLZ & Umkreis</span>
                    <span class="bento-tag">Software</span>
                    <span class="bento-tag">SSL</span>
                    <span class="bento-tag">CMP</span>
                    <span class="bento-tag">Bundesland</span>
                </div>
            </div>

            <!-- Website-Analyse -->
            <div class="bento-card">
                <div class="bento-icon icon-cyan">
                    <i class="bi bi-globe2"></i>
                </div>
                <h5>Website-Analyse</h5>
                <p>
                    Erfahren Sie, welche Technologien, CMS und Tools ein
                    Unternehmen einsetzt. Automatisch erkannt und kategorisiert.
                </p>
            </div>

            <!-- MCP-Server -->
            <div class="bento-card">
                <div class="bento-icon icon-purple">
                    <i class="bi bi-robot"></i>
                </div>
                <h5>MCP-Server</h5>
                <p>
                    Integrieren Sie unsere Datenbank direkt in Ihren KI-Agenten.
                    Vollautomatische Recherche und Beschaffung.
                </p>
            </div>

            <!-- DSGVO -->
            <div class="bento-card">
                <div class="bento-icon icon-emerald">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h5>DSGVO-konform</h5>
                <p>
                    Alle Daten stammen aus öffentlichen Quellen und werden
                    datenschutzkonform verarbeitet. Hosting in Deutschland.
                </p>
            </div>

            <!-- Technologie-Erkennung – breit -->
            <div class="bento-card bento-wide">
                <div class="bento-icon icon-purple">
                    <i class="bi bi-code-slash"></i>
                </div>
                <h5>Technologie-Erkennung</h5>
                <p>
                    Unser System erkennt automatisch CMS, Frameworks, Analytics-Tools
                    und weitere Technologien auf den Websites der Unternehmen.
                </p>
                <div class="bento-tag-list">
                    <span class="bento-tag">WordPress</span>
                    <span class="bento-tag">Shopware</span>
                    <span class="bento-tag">TYPO3</span>
                    <span class="bento-tag">Joomla</span>
                    <span class="bento-tag">Magento</span>
                    <span class="bento-tag">WooCommerce</span>
                    <span class="bento-tag">Google Analytics</span>
                    <span class="bento-tag">Matomo</span>
                    <span class="bento-tag">Cloudflare</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How it works -->
<section class="section-spacing section-bg-light">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-label">
                <i class="bi bi-lightning-charge"></i> So geht's
            </span>
            <h2>In drei Schritten zu neuen Kunden</h2>
        </div>
        <div class="process-steps">
            <div class="process-step">
                <div class="process-step-number">1</div>
                <h5>Registrieren</h5>
                <p>Erstellen Sie Ihr kostenloses Konto in weniger als einer Minute.</p>
            </div>
            <div class="process-step">
                <div class="process-step-number">2</div>
                <h5>Filtern & Finden</h5>
                <p>Nutzen Sie unsere Filter, um genau die Unternehmen zu finden, die zu Ihrem Angebot passen.</p>
            </div>
            <div class="process-step">
                <div class="process-step-number">3</div>
                <h5>Kontaktieren</h5>
                <p>Erwerben Sie Datensätze und starten Sie Ihre gezielte Akquise sofort.</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section-spacing">
    <div class="container">
        <div class="cta-section text-center">
            <h2>Bereit, neue Kunden zu finden?</h2>
            <p class="mt-3 mb-4" style="max-width: 480px; margin-left: auto; margin-right: auto;">
                Starten Sie jetzt kostenlos und entdecken Sie die passenden
                Unternehmen für Ihre Akquise.
            </p>
            <a href="/de/registrieren" class="btn-hero-primary">
                Jetzt kostenlos starten
                <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
</section>
