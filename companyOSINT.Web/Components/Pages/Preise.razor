@page "/de/preise"

<PageTitle>Preise - company-OSINT.com</PageTitle>

<section class="section-spacing">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-label">
                <i class="bi bi-tag"></i> Preise
            </span>
            <h2>Einfach und transparent</h2>
            <p>Wählen Sie das Paket, das zu Ihrem Bedarf passt. Alle Preise zzgl. MwSt.</p>
        </div>

        <div class="row g-4 justify-content-center mt-2">
            <!-- Web -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <div class="card-body d-flex flex-column">
                        <span class="badge rounded-pill mb-2 align-self-center" style="visibility: hidden;">Beliebt</span>
                        <h5 class="fw-bold mb-1">Web</h5>
                        <p class="text-muted small mb-3">Firmendaten im Browser</p>
                        <div class="mb-4">
                            <span class="display-5 fw-bold">49&thinsp;&euro;</span>
                            <span class="text-muted">/ Monat</span>
                        </div>
                        <ul class="list-unstyled text-start mb-4 flex-grow-1">
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Alle Filter nutzbar</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Website-Analyse inklusive</li>
                        </ul>
                        <a href="/de/registrieren" class="btn btn-outline-primary w-100">
                            Jetzt starten
                        </a>
                    </div>
                </div>
            </div>

            <!-- Web + MCP -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4" style="border: 2px solid var(--fac-primary) !important;">
                    <div class="card-body d-flex flex-column">
                        <span class="badge rounded-pill mb-2 align-self-center" style="background: var(--fac-primary);">Beliebt</span>
                        <h5 class="fw-bold mb-1">Web + MCP</h5>
                        <p class="text-muted small mb-3">Für KI-gestützte Akquise</p>
                        <div class="mb-4">
                            <span class="display-5 fw-bold">99&thinsp;&euro;</span>
                            <span class="text-muted">/ Monat</span>
                        </div>
                        <ul class="list-unstyled text-start mb-4 flex-grow-1">
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Alle Funktionen von Web</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>API-Token für den MCP-Server</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Einbindung in eigene KI-Agenten</li>
                        </ul>
                        <a href="/de/registrieren" class="btn btn-primary w-100">
                            Jetzt starten
                        </a>
                    </div>
                </div>
            </div>

            <!-- Enterprise -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <div class="card-body d-flex flex-column">
                        <span class="badge rounded-pill mb-2 align-self-center" style="visibility: hidden;">Beliebt</span>
                        <h5 class="fw-bold mb-1">Enterprise</h5>
                        <p class="text-muted small mb-3">Für große Teams</p>
                        <div class="mb-4">
                            <span class="display-5 fw-bold">Individuell</span>
                        </div>
                        <ul class="list-unstyled text-start mb-4 flex-grow-1">
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Alle Funktionen von Web + MCP</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Persönlicher Ansprechpartner</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Unterstützung bei der Integration in KI-Agenten</li>
                        </ul>
                        <a href="/de/kontakt" class="btn btn-outline-primary w-100">
                            Kontakt aufnehmen
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
