@page "/de/preise"

<PageTitle>Preise - company-OSINT.com</PageTitle>

<section class="section-spacing">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-label">
                <i class="bi bi-tag"></i> Preise
            </span>
            <h2>Einfach und transparent</h2>
            <p>Keine Abos, keine versteckten Kosten. Zahlen Sie nur für die Datensätze, die Sie brauchen.</p>
        </div>

        <div class="row g-4 justify-content-center mt-2">
            <!-- Starter -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <div class="card-body d-flex flex-column">
                        <h5 class="fw-bold mb-1">Starter</h5>
                        <p class="text-muted small mb-3">Zum Kennenlernen</p>
                        <div class="mb-4">
                            <span class="display-5 fw-bold">0&thinsp;&euro;</span>
                        </div>
                        <ul class="list-unstyled text-start mb-4 flex-grow-1">
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>10 kostenlose Datensätze</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Alle Filter nutzbar</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Website-Analyse inklusive</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>MCP-Server-Zugang</li>
                        </ul>
                        <a href="/de/registrieren" class="btn btn-outline-primary w-100">
                            Kostenlos starten
                        </a>
                    </div>
                </div>
            </div>

            <!-- Professional -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4" style="border: 2px solid var(--fac-primary) !important;">
                    <div class="card-body d-flex flex-column">
                        <span class="badge rounded-pill mb-2 align-self-center" style="background: var(--fac-primary);">Beliebt</span>
                        <h5 class="fw-bold mb-1">Professional</h5>
                        <p class="text-muted small mb-3">Für regelmäßige Akquise</p>
                        <div class="mb-4">
                            <span class="display-5 fw-bold">49&thinsp;&euro;</span>
                            <span class="text-muted">/ Monat</span>
                        </div>
                        <ul class="list-unstyled text-start mb-4 flex-grow-1">
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>500 Datensätze / Monat</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Alle Filter nutzbar</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Website-Analyse inklusive</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>MCP-Server-Zugang</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>CSV-Export</li>
                        </ul>
                        <a href="/de/registrieren" class="btn btn-primary w-100">
                            Jetzt starten
                        </a>
                    </div>
                </div>
            </div>

            <!-- Enterprise -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <div class="card-body d-flex flex-column">
                        <h5 class="fw-bold mb-1">Enterprise</h5>
                        <p class="text-muted small mb-3">Für große Teams</p>
                        <div class="mb-4">
                            <span class="display-5 fw-bold">Individuell</span>
                        </div>
                        <ul class="list-unstyled text-start mb-4 flex-grow-1">
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Unbegrenzte Datensätze</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Alle Filter nutzbar</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Website-Analyse inklusive</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>MCP-Server-Zugang</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Dedizierter Ansprechpartner</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>API-Zugang</li>
                        </ul>
                        <a href="/de/kontakt" class="btn btn-outline-primary w-100">
                            Kontakt aufnehmen
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
